{
  "$comment": "Example Claude Code settings.json wiring for the Lucy Syndrome hooks. Copy the 'hooks' key into your project's .claude/settings.json. Paths assume the hooks directory is at ./hooks/ relative to your working directory — adjust if you place the files elsewhere. Severity is warn-only: no hook blocks a tool call, they only inject context.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"./hooks/hook_session_start.py\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./hooks/hook_scar_001_docx.py\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python \"./hooks/hook_scar_002_size.py\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python \"./hooks/hook_scar_005_subagent.py\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
