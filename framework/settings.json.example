{
  "$comment": "Example Claude Code settings.json wiring for the Lucy Syndrome hooks. install.sh writes this verbatim to .claude/settings.json if no settings file exists yet; otherwise merge the 'hooks' key into your existing settings.json by hand. Adjust paths if you place hooks somewhere other than .claude/scarring/hooks/. All shipped hooks are warn-only: none block tool calls, they only inject reminder context. For richer trigger patterns (subagent batch coverage, prompt-time KB expansion, etc.), see examples/production-case/hooks/ in the repo and adapt to your domain.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/scarring/hooks/hook_session_start.py\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/scarring/hooks/hook_example_review.py\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
